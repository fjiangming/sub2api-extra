# Account Manager 的 Compose 与运行时配置示例。
# 复制为 .env 后使用；密码和密钥仅保留安全占位值，请按实际环境修改。

# Compose 部署参数。
ACCOUNT_MANAGER_IMAGE=ghcr.io/fjiangming/sub2api-extra:latest
ACCOUNT_MANAGER_CONTAINER_NAME=sub2api-account-manager
ACCOUNT_MANAGER_RESTART_POLICY=unless-stopped
ACCOUNT_MANAGER_DATA_PATH=./data

# Account Manager 运行参数。
NODE_ENV=production
PORT=3100

# 扩展接口密钥。留空时使用应用默认值；正式部署建议设置独立随机值。
EXT_SECRET=

# 从源码构建镜像时使用的 npm registry。
NPM_REGISTRY=https://registry.npmmirror.com/

# 基座 Sub2API 地址与管理员账号。
SUB2API_BASE_URL=http://localhost:8080
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_your_admin_password

# Account Manager 暴露到宿主机的端口。
ACCOUNT_MANAGER_PORT=9870
