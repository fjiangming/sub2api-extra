# ===== 构建配置（仅影响 docker compose build）=====
# 中国大陆服务器请取消注释，海外服务器留空或删除
# NPM_REGISTRY=https://registry.npmmirror.com/

# ===== 运行配置 =====
# 本模块运行使用的端口
# PORT=3100

# Sub2API 后端 API 地址（如果你通过 Docker 运行并且 Sub2API 在本机，请使用 host.docker.internal）
SUB2API_BASE_URL=http://host.docker.internal:8080

# 你的 Sub2API 管理员账号（用于进行 OAuth 等鉴权请求代理）
ADMIN_EMAIL=admin@sub2api.local
ADMIN_PASSWORD=your_admin_password_here
