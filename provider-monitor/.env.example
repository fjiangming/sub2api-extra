# =============================================================================
# Provider Monitor 的 Compose 与运行时统一配置示例
#
# 启动命令：
#   npm start
#
# 复制为 .env 后使用，修改后必须重启 Provider Monitor 才会生效。
# 密码、Token 和 PROVIDER_MONITOR_SECRET 均为安全占位值或空值，请勿照搬到生产环境。
# =============================================================================

# -----------------------------------------------------------------------------
# 0. Compose 部署参数
# -----------------------------------------------------------------------------
PROVIDER_MONITOR_IMAGE=ghcr.io/fjiangming/sub2api-extra:provider-monitor-latest
PROVIDER_MONITOR_CONTAINER_NAME=sub2api-provider-monitor
PROVIDER_MONITOR_RESTART_POLICY=unless-stopped
PROVIDER_MONITOR_PORT=9871
PROVIDER_MONITOR_DATA_VOLUME=sub2api-extra_provider-monitor-data
NPM_REGISTRY=https://registry.npmmirror.com/

# -----------------------------------------------------------------------------
# 1. 基础运行参数
# -----------------------------------------------------------------------------
# Node.js 运行环境。
# development：本地开发，静态文件不启用生产缓存。
# production：正式部署。
NODE_ENV=development

# Provider Monitor 监听端口。
# 当前页面地址为 http://127.0.0.1:9872/。
PORT=9872

# -----------------------------------------------------------------------------
# 2. 数据存储与加密
# -----------------------------------------------------------------------------
# 数据目录与 SQLite 文件路径。相对路径以 provider-monitor 目录为基准。
PROVIDER_MONITOR_DATA_DIR=./data
PROVIDER_MONITOR_DATABASE=./data/provider-monitor.db

# 必填：用于加密敏感配置，至少 32 个字符，并在部署后保持不变。
PROVIDER_MONITOR_SECRET=replace_with_a_random_secret_of_32_chars_or_more

# -----------------------------------------------------------------------------
# 3. Provider Monitor 登录方式
# -----------------------------------------------------------------------------
# local：使用下方本地管理员账号登录。
# sub2api：使用基座 Sub2API 管理员账号登录。
PROVIDER_MONITOR_AUTH_MODE=local
PROVIDER_MONITOR_LOCAL_ADMIN_USER=admin
PROVIDER_MONITOR_LOCAL_ADMIN_PASSWORD=replace_with_your_local_admin_password
# 已配置密码哈希时优先使用哈希；与明文密码二选一即可。
PROVIDER_MONITOR_LOCAL_ADMIN_PASSWORD_HASH=

# -----------------------------------------------------------------------------
# 4. 基座 Sub2API
# -----------------------------------------------------------------------------
# 后端访问地址与浏览器可访问的公开地址。
SUB2API_BASE_URL=http://localhost:8080
SUB2API_PUBLIC_URL=http://localhost:8080
# 可直接填写管理员 Token；留空时使用下方管理员账号获取 Token。
SUB2API_ADMIN_TOKEN=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# 5. 仅启动时生效的进程参数
# -----------------------------------------------------------------------------
# 以下值均显式集中在本文件中。网页“设置与备份 -> 系统参数”保存的值
# 会持久化到 SQLite，并在运行时覆盖对应的启动默认值。
PROVIDER_MONITOR_SESSION_TTL_MINUTES=480
PROVIDER_MONITOR_QUERY_TIMEOUT_MS=15000
PROVIDER_MONITOR_MAX_RESPONSE_BYTES=2097152
PROVIDER_MONITOR_CONCURRENCY=5
PROVIDER_MONITOR_PROVIDER_CONCURRENCY=2
PROVIDER_MONITOR_KEY_HEALTH_CONCURRENCY=3
PROVIDER_MONITOR_REFRESH_MINUTES=15
PROVIDER_MONITOR_STALE_MINUTES=60
PROVIDER_MONITOR_RAW_SNAPSHOT_RETENTION_DAYS=30
PROVIDER_MONITOR_SNAPSHOT_RETENTION_DAYS=180
PROVIDER_MONITOR_JOB_RETENTION_DAYS=90
PROVIDER_MONITOR_AUDIT_RETENTION_DAYS=365
PROVIDER_MONITOR_NOTIFICATION_RETENTION_DAYS=180
# 留空时放行所有私网供应商；填写后仅放行逗号分隔的主机名单。
PROVIDER_MONITOR_ALLOWED_HOSTS=
# 仅在上方名单非空时生效；true 表示忽略名单并放行所有私网供应商。
PROVIDER_MONITOR_ALLOW_PRIVATE_NETWORKS=false
PROVIDER_MONITOR_ALLOWED_ORIGINS=
PROVIDER_MONITOR_METRICS_ENABLED=true
PROVIDER_MONITOR_AUTOMATION_ENABLED=false
PROVIDER_MONITOR_LOG_LEVEL=info
PROVIDER_MONITOR_TIMEZONE=Asia/Shanghai

# 旧版 SMTP 环境变量仅作兼容回退；新部署优先在通知通道中配置。
PROVIDER_MONITOR_SMTP_HOST=
PROVIDER_MONITOR_SMTP_PORT=587
PROVIDER_MONITOR_SMTP_SECURE=false
PROVIDER_MONITOR_SMTP_USER=
PROVIDER_MONITOR_SMTP_PASSWORD=
PROVIDER_MONITOR_SMTP_FROM=
